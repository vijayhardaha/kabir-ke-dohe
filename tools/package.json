{
  "name": "@kabir-dohe-hub/tools",
  "version": "1.0.0",
  "description": "Kabir Dohe Tools — CLI tools for data sync, image generation, and maintenance",
  "type": "module",
  "scripts": {
    "couplets:fetch": "bun --env-file=.env.development run src/scripts/couplets-fetch.ts",
    "couplets:fetch:prod": "NODE_ENV=production bun --env-file=.env.production run src/scripts/couplets-fetch.ts",
    "couplets:upload": "bun --env-file=.env.development run src/scripts/couplets-upload.ts",
    "couplets:upload:prod": "NODE_ENV=production bun --env-file=.env.production run src/scripts/couplets-upload.ts",
    "couplets:template:serve": "bun run src/scripts/template-serve.ts",
    "couplets:images": "bun run src/scripts/images-generate.ts",
    "couplets:images:optimize": "bun run src/scripts/images-optimize.ts",
    "couplets:images:upload": "bun --env-file=.env.development run src/scripts/images-upload.ts",
    "couplets:images:upload:prod": "NODE_ENV=production bun --env-file=.env.production run src/scripts/images-upload.ts",
    "tags:generate": "bun --env-file=.env.development run src/scripts/tags-generate.ts",
    "tags:generate:prod": "NODE_ENV=production bun --env-file=.env.production run src/scripts/tags-generate.ts",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "Kabir",
    "dohe",
    "tools"
  ],
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha"
  },
  "license": "MIT",
  "homepage": "https://github.com/vijayhardaha/kabir-dohe-api/tree/master/tools",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijayhardaha/kabir-dohe-api.git",
    "directory": "tools"
  },
  "bugs": {
    "url": "https://github.com/vijayhardaha/kabir-dohe-api/issues"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "browser-sync": "^3.0.4",
    "chokidar": "^5.0.0",
    "google-auth-library": "^10.7.0",
    "google-spreadsheet": "^5.3.0",
    "juice": "^12.1.1",
    "ora": "^9.4.0",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@vijayhardaha/dev-config": "^2.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
