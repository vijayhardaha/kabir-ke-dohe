            </a>
            <a class="footer__social-link" href="https://www.instagram.com/kabirkedohe.official">
              <svg
                class="footer__icon"
                stroke="currentColor"
                fill="currentColor"
                stroke-width="0"
                viewBox="0 0 256 256"
                xmlns="http://www.w3.org/2000/svg"
              ><path
