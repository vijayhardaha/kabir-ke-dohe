<html lang="hi">

  <head>
    <meta charset="UTF-8" />
    <link
      href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@300..800&family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Hind:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="card">
      <svg class="card__bg" viewBox="0 0 1080 1080" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M967 1080L959 0L1080 0L1080 1080Z" fill="{{svg_color_1}}" />
        <path d="M803 1080L759 0L960 0L968 1080Z" fill="{{svg_color_2}}" />
        <path d="M539 1080L453 0L760 0L804 1080Z" fill="{{svg_color_3}}" />
        <path d="M267 1080L301 0L454 0L540 1080Z" fill="{{svg_color_4}}" />
        <path d="M0 1080L0 0L302 0L268 1080Z" fill="{{svg_color_5}}" />
      </svg>
      <div class="card__content">
        <div class="heading">कबीर के दोहे</div>
        <div class="divider"></div>
        <div class="couplet">{{couplet_text}}</div>
        <div class="meaning">{{couplet_meaning}}</div>
        <div class="spacer"></div>
        <div class="bottom-divider"></div>
        <div class="footer">
          <span class="footer__website">{{website_url}}</span>
          <div class="footer__socials">
            <a class="footer__social-link" href="https://www.facebook.com/kabirkedohe.official">
              <svg
                class="footer__icon"
                stroke="currentColor"
                fill="currentColor"
                stroke-width="0"
                viewBox="0 0 256 256"
                xmlns="http://www.w3.org/2000/svg"
