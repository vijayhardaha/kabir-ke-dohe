# ========================================================================
# Kabir Dohe Tools — Environment Variables
# ========================================================================
# Copy this file to .env.development or .env.production and fill in the
# values for your environment.
# ========================================================================

# Supabase (service role key for write operations)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Sheets (for data upload)
GOOGLE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
GOOGLE_SHEET_ID=your-google-sheet-id

# Environment
NODE_ENV=development
