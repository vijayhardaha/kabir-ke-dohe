# ========================================================================
# Kabir Dohe API — Environment Variables
# ========================================================================
# Copy this file to .env.development or .env.production and fill in the
# values for your environment.
# ========================================================================

# Supabase (project-level, not NEXT_PUBLIC_* prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-or-service-role-key

# Tools / admin operations (service role key, keep secret)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site
NEXT_PUBLIC_SITE_URL=https://your-site-url.com

# NODE_ENV is also required by the Zod schema
NODE_ENV=development
