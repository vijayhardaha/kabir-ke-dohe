// =======================================================================
// Typescript Configuration
// =======================================================================
// Purpose: Static type-checking and module resolution strategy for the
//          repository, ensuring predictable behavior and strong typing
//          across code.
// Docs:    https://www.typescriptlang.org/tsconfig
// =======================================================================

{
  "extends": "@vijayhardaha/dev-config/tsconfig",
  "compilerOptions": {
    "paths": { "@/*": ["./src/*"] },
    // ----------------------------------------------------------------------
    // Plugins & extras
    // ----------------------------------------------------------------------
    "plugins": [{ "name": "next" }]
  },

  // ---- Includes ----
  // Files to include in the project type-checking scope
  "include": [
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    "*.config.mjs",
    "*.config.ts",
    "*.d.ts",
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mjs",
    "**/*.cjs",
    "next-env.d.ts"
  ],

  // ---- Excludes ----
  "exclude": ["node_modules", "docs", "dist", "build", "coverage", ".next"]
}
