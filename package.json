{
  "name": "kabir-dohe-api",
  "version": "1.0.0",
  "description": "An API for fetching and filtering Kabir's dohas, built with Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "start": "next start",
    "build": "next build && next-sitemap",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write --log-level error .",
    "format:check": "prettier --check --log-level error .",
    "indexnow": "bun run scripts/indexnow.ts",
    "sync": "bun --env-file=.env.local scripts/sync.ts",
    "sync:prod": "bun --env-file=.env.production scripts/sync.ts",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "Kabir",
    "dohe",
    "Next.js",
    "API",
    "Vercel"
  ],
  "license": "MIT",
  "homepage": "https://kabirdohe-api.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijayhardaha/kabir-dohe-api.git"
  },
  "bugs": {
    "url": "https://github.com/vijayhardaha/kabir-dohe-api/issues"
  },
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.7",
    "@supabase/supabase-js": "^2.107.0",
    "@vijayhardaha/schema-builder": "^1.0.6",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "latinize": "^2.0.0",
    "next": "^16.2.7",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "slugify": "^1.6.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@eslint/compat": "^2.1.0",
    "@next/eslint-plugin-next": "^16.2.7",
    "@prettier/plugin-xml": "^3.4.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/latinize": "^0.2.18",
    "@types/node": "25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vijayhardaha/dev-config": "^2.0.4",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "google-auth-library": "^10.6.2",
    "google-spreadsheet": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "next-sitemap": "^4.2.3",
    "ollama": "^0.6.3",
    "ora": "^9.4.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8",
    "xml2js": "^0.6.2"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
