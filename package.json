{
  "name": "kabir-hub",
  "version": "1.0.0",
  "description": "Kabir Hub — Monorepo for Kabir Dohe API, Web, and Images Tool",
  "private": true,
  "workspaces": [
    "api",
    "web",
    "images-tool"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "lint": "bun run --filter '*' lint",
    "lint:fix": "bun run --filter '*' lint:fix",
    "format": "prettier --write --log-level error .",
    "format:check": "prettier --check .",
    "tsc": "bun run --filter '*' tsc",
    "test": "bun run --filter '*' test",
    "test:coverage": "bun run --filter '*' test:coverage",
    "prepare": "husky"
  },
  "keywords": [
    "Kabir",
    "dohe",
    "monorepo"
  ],
  "license": "MIT",
  "homepage": "https://kabirdoheapi.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijayhardaha/kabir-dohe-api.git"
  },
  "bugs": {
    "url": "https://github.com/vijayhardaha/kabir-dohe-api/issues"
  },
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@eslint/compat": "^2.1.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@vijayhardaha/dev-config": "^2.1.1",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
