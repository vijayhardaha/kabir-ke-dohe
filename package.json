{
  "name": "kabir-hub",
  "version": "1.0.0",
  "description": "Kabir Hub — Monorepo for Kabir Dohe API, Web, and Images Tool",
  "private": true,
  "workspaces": [
    "api",
    "web",
    "images-tool"
  ],
  "scripts": {
    "format": "prettier --write --log-level error .",
    "format:check": "prettier --check --log-level error .",
    "prepare": "husky",
    "dev": "bun run dev:api",
    "dev:api": "bun run --filter='@kabir-hub/api' dev",
    "dev:web": "bun run --filter='@kabir-hub/web' dev",
    "dev:images": "bun run --filter='@kabir-hub/images-tool' dev",
    "build": "bun run build:api",
    "build:api": "bun run --filter='@kabir-hub/api' build",
    "build:web": "bun run --filter='@kabir-hub/web' build",
    "build:images": "bun run --filter='@kabir-hub/images-tool' build",
    "lint": "bun run lint:api",
    "lint:api": "bun run --filter='@kabir-hub/api' lint",
    "lint:web": "bun run --filter='@kabir-hub/web' lint",
    "lint:images": "bun run --filter='@kabir-hub/images-tool' lint",
    "lint:fix": "bun run lint:fix:api",
    "lint:fix:api": "bun run --filter='@kabir-hub/api' lint:fix",
    "lint:fix:web": "bun run --filter='@kabir-hub/web' lint:fix",
    "lint:fix:images": "bun run --filter='@kabir-hub/images-tool' lint:fix",
    "tsc": "bun run tsc:api",
    "tsc:api": "bun run --filter='@kabir-hub/api' tsc",
    "tsc:web": "bun run --filter='@kabir-hub/web' tsc",
    "tsc:images": "bun run --filter='@kabir-hub/images-tool' tsc"
  },
  "keywords": [
    "Kabir",
    "dohe",
    "monorepo"
  ],
  "license": "MIT",
  "homepage": "https://kabirdoheapi.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijayhardaha/kabir-dohe-api.git"
  },
  "bugs": {
    "url": "https://github.com/vijayhardaha/kabir-dohe-api/issues"
  },
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@eslint/compat": "^2.1.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@vijayhardaha/dev-config": "^2.0.4",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
